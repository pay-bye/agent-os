{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "v1.schema.json",
  "type": "object",
  "required": [
    "version",
    "tag",
    "commit",
    "source",
    "artifacts",
    "images",
    "checksums",
    "sboms",
    "signatures",
    "provenance",
    "attestations",
    "homebrew",
    "notes",
    "rollback"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "tag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(-rc\\.[0-9]+)?$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "source": { "$ref": "#/$defs/source" },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "images": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/image" }
    },
    "checksums": { "$ref": "#/$defs/checksums" },
    "sboms": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reference" }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reference" }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reference" }
    },
    "attestations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reference" }
    },
    "homebrew": { "$ref": "#/$defs/homebrew" },
    "notes": { "$ref": "#/$defs/notes" },
    "rollback": { "$ref": "#/$defs/rollback" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["repository", "workflow", "run_id"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "workflow": { "type": "string", "const": "release-agent-os.yml" },
        "run_id": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["name", "os", "arch", "checksum", "signature", "sbom", "attestation"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "os": { "type": "string", "enum": ["linux", "darwin"] },
        "arch": { "type": "string", "enum": ["amd64", "arm64"] },
        "checksum": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 },
        "sbom": { "type": "string", "minLength": 1 },
        "attestation": { "type": "string", "minLength": 1 }
      }
    },
    "image": {
      "type": "object",
      "required": ["name", "tag", "platform", "digest", "signature", "sbom", "provenance", "attestation"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^ghcr\\.io/.+" },
        "tag": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "enum": ["linux/amd64", "linux/arm64"] },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "signature": { "type": "string", "minLength": 1 },
        "sbom": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "attestation": { "type": "string", "minLength": 1 }
      }
    },
    "checksums": {
      "type": "object",
      "required": ["file", "algorithm", "signature", "attestation"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string", "const": "checksums.txt" },
        "algorithm": { "type": "string", "const": "sha256" },
        "signature": { "type": "string", "minLength": 1 },
        "attestation": { "type": "string", "minLength": 1 }
      }
    },
    "reference": {
      "type": "object",
      "required": ["subject", "uri"],
      "additionalProperties": false,
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 }
      }
    },
    "homebrew": {
      "type": "object",
      "required": ["status", "cask_token", "tap_repository", "commit", "path", "reason"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["published", "publication_blocked"] },
        "cask_token": { "type": "string", "const": "agent-os" },
        "tap_repository": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "const": "Casks/agent-os.rb" },
        "reason": { "type": "string", "enum": ["none", "public_destination_missing"] }
      }
    },
    "notes": {
      "type": "object",
      "required": ["release_url", "install", "verify", "upgrade", "rollback"],
      "additionalProperties": false,
      "properties": {
        "release_url": { "type": "string", "minLength": 1 },
        "install": { "type": "string", "minLength": 1 },
        "verify": { "type": "string", "minLength": 1 },
        "upgrade": { "type": "string", "minLength": 1 },
        "rollback": { "type": "string", "minLength": 1 }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["disposition", "recovery", "immutable_warning"],
      "additionalProperties": false,
      "properties": {
        "disposition": { "type": "string", "enum": ["candidate", "active", "withdrawn", "superseded"] },
        "recovery": { "type": "string", "minLength": 1 },
        "immutable_warning": { "type": "string", "minLength": 1 }
      }
    }
  }
}
