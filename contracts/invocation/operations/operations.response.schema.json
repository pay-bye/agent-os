{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operations.response.schema.json",
  "type": "object",
  "required": ["generated_at", "result", "window_seconds", "views", "unavailable"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "result": {
      "oneOf": [
        { "type": "string", "const": "complete" },
        { "type": "string", "const": "partial" }
      ]
    },
    "window_seconds": {
      "type": "integer",
      "const": 300
    },
    "views": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queue": {
          "type": "object",
          "required": ["channel_class", "depth", "available", "oldest_available_age_seconds"],
          "additionalProperties": false,
          "properties": {
            "channel_class": { "type": "string", "const": "all" },
            "depth": { "type": "integer", "minimum": 0 },
            "available": { "type": "integer", "minimum": 0 },
            "oldest_available_age_seconds": { "type": "integer", "minimum": 0 }
          }
        },
        "leases": {
          "type": "object",
          "required": ["channel_class", "held", "expired"],
          "additionalProperties": false,
          "properties": {
            "channel_class": { "type": "string", "const": "all" },
            "held": { "type": "integer", "minimum": 0 },
            "expired": { "type": "integer", "minimum": 0 }
          }
        },
        "journal": {
          "type": "object",
          "required": ["append_rate_per_second", "window_seconds"],
          "additionalProperties": false,
          "properties": {
            "append_rate_per_second": { "type": "number", "minimum": 0 },
            "window_seconds": { "type": "integer", "const": 300 }
          }
        },
        "commands": {
          "type": "object",
          "required": ["succeeded", "failed"],
          "additionalProperties": false,
          "properties": {
            "succeeded": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 }
          }
        },
        "routing": {
          "type": "object",
          "required": ["routed", "unrouted"],
          "additionalProperties": false,
          "properties": {
            "routed": { "type": "integer", "minimum": 0 },
            "unrouted": { "type": "integer", "minimum": 0 }
          }
        },
        "build": {
          "type": "object",
          "required": ["version", "revision"],
          "additionalProperties": false,
          "properties": {
            "version": { "type": "string", "minLength": 1 },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "compatibility": {
          "type": "object",
          "required": ["contract_version", "features", "routes"],
          "additionalProperties": false,
          "properties": {
            "contract_version": { "type": "string", "const": "v1" },
            "features": {
              "type": "array",
              "minItems": 7,
              "maxItems": 7,
              "uniqueItems": true,
              "items": {
                "oneOf": [
                  { "type": "string", "const": "lease_claim" },
                  { "type": "string", "const": "lease_extend" },
                  { "type": "string", "const": "lease_ack" },
                  { "type": "string", "const": "lease_nack" },
                  { "type": "string", "const": "lease_capability" },
                  { "type": "string", "const": "declared_needs" },
                  { "type": "string", "const": "failure_payload" }
                ]
              }
            },
            "routes": {
              "type": "array",
              "minItems": 24,
              "maxItems": 24,
              "uniqueItems": true,
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/submit" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/claim" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/ack" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/nack" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/extend" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/heartbeat" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/pause" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/release-expired-lease" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/force-release-lease" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/move-item" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/move-entries" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/move-available" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/drop" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "POST" },
                      "path": { "type": "string", "const": "/operations/instructions/route-outstanding" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/health" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/readyz" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/metrics" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations/channels" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations/channels/{channel_key}/items" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations/items/{work_item_id}" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations/items/{work_item_id}/journal" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/operations/nodes" }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["method", "path"],
                    "additionalProperties": false,
                    "properties": {
                      "method": { "type": "string", "const": "GET" },
                      "path": { "type": "string", "const": "/compatibility" }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "unavailable": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "const": "queue" },
          { "type": "string", "const": "leases" },
          { "type": "string", "const": "journal" },
          { "type": "string", "const": "commands" },
          { "type": "string", "const": "routing" },
          { "type": "string", "const": "build" },
          { "type": "string", "const": "compatibility" }
        ]
      }
    }
  }
}
