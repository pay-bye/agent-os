{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operations.item.response.schema.json",
  "type": "object",
  "required": ["work_item_id", "item_kind", "submitted_at"],
  "additionalProperties": false,
  "properties": {
    "work_item_id": { "type": "string", "minLength": 1 },
    "item_kind": { "type": "string", "minLength": 1 },
    "submitted_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "channel_entry": {
      "type": "object",
      "required": ["entry_id", "channel_key", "node_key", "enqueued_at", "available_at", "age_seconds"],
      "additionalProperties": false,
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "channel_key": { "type": "string", "minLength": 1 },
        "node_key": { "type": "string", "minLength": 1 },
        "enqueued_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "available_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "age_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "lease": {
      "type": "object",
      "required": ["lease_id", "channel_key", "granted_at", "expires_at"],
      "additionalProperties": false,
      "properties": {
        "lease_id": { "type": "string", "minLength": 1 },
        "channel_key": { "type": "string", "minLength": 1 },
        "granted_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "expires_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }
      }
    },
    "outstanding_need": {
      "type": "object",
      "required": ["event_id", "need_kind", "declared_at"],
      "additionalProperties": false,
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "need_kind": { "type": "string", "minLength": 1 },
        "target_node": { "type": "string", "minLength": 1 },
        "declared_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }
      }
    }
  }
}
