{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "instruction.move-item.request.schema.json",
  "type": "object",
  "required": ["instruction_id", "work_item_id", "source_channel_key", "target_channel_key"],
  "additionalProperties": false,
  "properties": {
    "instruction_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^\\S+$"
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "source_channel_key": {
      "type": "string",
      "minLength": 1
    },
    "target_channel_key": {
      "type": "string",
      "minLength": 1
    }
  }
}
