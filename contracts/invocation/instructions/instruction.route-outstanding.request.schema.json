{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "instruction.route-outstanding.request.schema.json",
  "type": "object",
  "required": ["instruction_id", "work_item_ids"],
  "additionalProperties": false,
  "properties": {
    "instruction_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^\\S+$"
    },
    "work_item_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
