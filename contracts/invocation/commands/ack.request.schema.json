{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ack.request.schema.json",
  "type": "object",
  "required": ["lease_id", "lease_token", "declared_needs"],
  "additionalProperties": false,
  "properties": {
    "lease_id": {"type": "string", "minLength": 1},
    "lease_token": {"type": "string", "minLength": 1},
    "declared_needs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["need_kind"],
        "additionalProperties": false,
        "properties": {
          "need_kind": {"type": "string", "minLength": 1},
          "target_node": {"type": "string", "minLength": 1},
          "payload": {"type": "object"}
        }
      }
    }
  }
}
