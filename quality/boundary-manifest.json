{
  "schema_version": 1,
  "root": ".",
  "allowed_top_level_roots": {
    "rule": "top-level-source-root-category-preservation",
    "names": [
      "go.mod",
      "go.sum",
      "CODE_OF_CONDUCT.md",
      "CONTRIBUTING.md",
      "GOVERNANCE.md",
      "LICENSE",
      "README.md",
      "SECURITY.md",
      "cmd",
      "internal",
      "contracts",
      "tests",
      "scripts",
      "quality",
      "docs"
    ],
    "message": "top-level source roots are limited to the declared categories"
  },
  "internal_packages": [
    "internal/channel",
    "internal/config",
    "internal/declaration",
    "internal/declaration/execution",
    "internal/journal",
    "internal/journal/payloads",
    "internal/kernel",
    "internal/kernel/claiming",
    "internal/kernel/instructions",
    "internal/kernel/leases",
    "internal/kernel/pause",
    "internal/kernel/resolution",
    "internal/kernel/routing",
    "internal/kernel/submission",
    "internal/metrics",
    "internal/process/ids",
    "internal/processlog",
    "internal/readmodel",
    "internal/readmodel/postgres",
    "internal/registry",
    "internal/storage/postgres",
    "internal/storage/postgres/catalog",
    "internal/storage/postgres/channel",
    "internal/storage/postgres/journal",
    "internal/storage/postgres/kernel",
    "internal/storage/postgres/metrics",
    "internal/storage/postgres/migrations",
    "internal/storage/postgres/registry",
    "internal/transport/http",
    "internal/transport/http/codec",
    "internal/transport/http/commands",
    "internal/transport/http/compatibility",
    "internal/transport/http/diagnostics",
    "internal/transport/http/instructions",
    "internal/transport/http/operations",
    "internal/transport/http/probes",
    "internal/transport/http/scrape",
    "internal/transport/http/security",
    "internal/transport/http/security/credential",
    "internal/workitem"
  ],
  "forbidden_imports": [
    {
      "rule": "readmodel-import-boundary",
      "from": [
        "internal/channel",
        "internal/config",
        "internal/declaration",
        "internal/declaration/execution",
        "internal/journal",
        "internal/journal/payloads",
        "internal/kernel",
        "internal/kernel/claiming",
        "internal/kernel/instructions",
        "internal/kernel/leases",
        "internal/kernel/pause",
        "internal/kernel/resolution",
        "internal/kernel/routing",
        "internal/kernel/submission",
        "internal/metrics",
        "internal/process/ids",
        "internal/registry",
        "internal/storage/postgres",
        "internal/storage/postgres/catalog",
        "internal/storage/postgres/channel",
        "internal/storage/postgres/journal",
        "internal/storage/postgres/kernel",
        "internal/storage/postgres/metrics",
        "internal/storage/postgres/migrations",
        "internal/storage/postgres/registry",
        "internal/transport/http",
        "internal/transport/http/codec",
        "internal/transport/http/commands",
        "internal/transport/http/compatibility",
        "internal/transport/http/diagnostics",
        "internal/transport/http/instructions",
        "internal/transport/http/operations",
        "internal/transport/http/probes",
        "internal/transport/http/scrape",
        "internal/transport/http/security",
        "internal/transport/http/security/credential"
      ],
      "to": [
        "github.com/pay-bye/agent-os/internal/readmodel"
      ],
      "message": "operational read model stays out of authority and transport packages"
    },
    {
      "rule": "kernel-child-root-import-boundary",
      "from": [
        "internal/kernel/claiming",
        "internal/kernel/instructions",
        "internal/kernel/leases",
        "internal/kernel/pause",
        "internal/kernel/resolution",
        "internal/kernel/routing",
        "internal/kernel/submission"
      ],
      "to": [
        "github.com/pay-bye/agent-os/internal/kernel"
      ],
      "message": "kernel command children do not import the root facade"
    }
  ],
  "forbidden_packages": [
    {
      "under": "internal",
      "rule": "internal-toplevel-name-in-disallowed-list",
      "names": [
        "util",
        "helpers",
        "helper",
        "common",
        "shared",
        "misc",
        "core",
        "types",
        "service",
        "manager",
        "handler",
        "api",
        "processor"
      ],
      "message": "package name does not state a local responsibility"
    },
    {
      "under": "internal",
      "rule": "nested-internal-disallowed-name",
      "names": [
        "invocation",
        "adapter",
        "driver",
        "runtime",
        "codex",
        "claude",
        "agents"
      ],
      "message": "runtime and driver concerns live in their own software"
    }
  ],
  "forbidden_paths": [
    {
      "rule": "rejected-executable-source-path",
      "pattern": "cmd/{agent-os,agentos}/**",
      "message": "executable source paths name local responsibility rather than product identity"
    },
    {
      "rule": "top-level-tests-unit-directory",
      "pattern": "tests/unit/**",
      "message": "top-level unit tests are forbidden; package tests colocate with source"
    },
    {
      "rule": "boundary-test-outside-central-location",
      "pattern": "**/boundary_test.go",
      "message": "boundary enforcement is central under tests/architecture"
    },
    {
      "rule": "gitkeep-file-present",
      "pattern": "**/.gitkeep",
      "message": "empty scaffold directories are forbidden"
    },
    {
      "rule": "adapters-root-path-present",
      "pattern": "adapters/**",
      "message": "drivers live in the invocation-layer software"
    },
    {
      "rule": "nested-internal-disallowed-name",
      "pattern": "internal/**/{invocation,adapter,driver,runtime,codex,claude,agents}/**",
      "message": "runtime and driver concerns are forbidden at nested depth"
    },
    {
      "rule": "contract-in-internal",
      "pattern": "internal/**/contracts/**",
      "message": "contracts live under contracts, not under internal packages"
    }
  ],
  "migration_files": {
    "rule": "migration-outside-storage",
    "allowed_root": "internal/storage/postgres/migrations",
    "file_patterns": [
      "*.sql"
    ],
    "forbidden_elsewhere": [
      "**/migrations/*.sql",
      "**/*.up.sql",
      "**/*.down.sql"
    ],
    "message": "migration files live under the Postgres storage adapter"
  },
  "contract_documents": {
    "rule": "contract-in-internal",
    "allowed_root": "contracts",
    "file_patterns": [
      "*.schema.json",
      "*.openapi.json",
      "*.openapi.yaml",
      "*.openapi.yml"
    ],
    "forbidden_roots": [
      "internal"
    ],
    "message": "contract documents live under contracts"
  },
  "locations": {
    "architecture_tests": "tests/architecture",
    "postgres_migrations": "internal/storage/postgres/migrations",
    "contracts": "contracts"
  },
  "transport": {
    "root": "internal/transport",
    "subdirectories_must_be_protocols": true,
    "allowed_protocols": [
      "http"
    ]
  }
}
